<script>
/* ─── CURSOR ─── */
const cur=document.getElementById('cur');
let mx=0,my=0,cx=0,cy=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
(function ac(){cx+=(mx-cx)*.12;cy+=(my-cy)*.12;cur.style.left=cx+'px';cur.style.top=cy+'px';requestAnimationFrame(ac)})();



/* ─── SCROLL REVEAL ─── */
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.07});
document.querySelectorAll('.up').forEach(el=>obs.observe(el));

/* ─── ANIMATED BARS ─── */
const barObs=new IntersectionObserver(es=>{
  es.forEach(entry=>{
    if(!entry.isIntersecting)return;
    entry.target.querySelectorAll('[data-w]').forEach(el=>{
      const tw=el.dataset.w;
      el.style.width='0%';
      requestAnimationFrame(()=>{ el.style.transition='width 1.1s cubic-bezier(.16,1,.3,1)'; el.style.width=tw+'%'; });
    });
    barObs.unobserve(entry.target);
  });
},{threshold:.1});
document.querySelectorAll('.trend-card,.verticals-list,.geo-card,.arch-grid,.hero-panel').forEach(el=>barObs.observe(el));

/* ─── HERO PANEL Q-BARS ─── */
const aP=[14.4,16.7,19.5,19.5];
['q1bar','q2bar','q3bar','q4bar'].forEach((id,i)=>{
  const el=document.getElementById(id);
  if(el){el.style.height='0';setTimeout(()=>{el.style.transition='height 1s cubic-bezier(.16,1,.3,1)';el.style.height=(aP[i]/20*100)+'%'},800);}
});

/* ─── 3D CARD TILT ON MOUSE ─── */
document.querySelectorAll('.trend-card,.arch-item,.insight-card,.geo-card').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const x=((e.clientX-r.left)/r.width-.5)*12;
    const y=((e.clientY-r.top)/r.height-.5)*-10;
    card.style.transform=`perspective(500px) rotateX(${y}deg) rotateY(${x}deg) translateZ(8px)`;
  });
  card.addEventListener('mouseleave',()=>{
    card.style.transform='';
    card.style.transition='transform .5s cubic-bezier(.4,0,.2,1),box-shadow .5s';
  });
});

/* ─── PARALLAX ON SCROLL ─── */
const heroPanel=document.querySelector('.hero-panel');
window.addEventListener('scroll',()=>{
  const sy=window.scrollY;
  if(heroPanel) heroPanel.style.transform=`perspective(800px) rotateY(-6deg) rotateX(${2-sy*0.003}deg) translateY(${-sy*0.04}px)`;
},{ passive:true });
</script>


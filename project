<script>
// ── LIVE DATA FROM CSV ──────────────────────────────────────────────
const D = JSON.parse(document.getElementById('yc-data-raw').textContent);

// Helper to animate a number from 0 to target
function countUp(el, target, suffix='', decimals=0, duration=1400) {
  let start = null;
  const step = ts => {
    if (!start) start = ts;
    const p = Math.min((ts - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    const val = (target * ease).toFixed(decimals);
    el.textContent = val + suffix;
    if (p < 1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}

// Update hero stats
function applyHeroStats() {
  const statNums = document.querySelectorAll('.hs-n');
  const statLabels = document.querySelectorAll('.hs-l');
  const vals = [D.total, D.ai_pct, D.agent_pct, Object.keys(D.batches).length];
  const suffixes = ['', '%', '%', '개'];
  const decimals = [0, 1, 1, 0];
  const labels = ['YC 2025 스타트업', 'AI 침투율', '에이전트 비율', '배치'];
  statNums.forEach((el, i) => {
    if (vals[i] !== undefined) {
      el.dataset.target = vals[i];
      el.dataset.suffix = suffixes[i];
      el.dataset.dec = decimals[i];
    }
  });
  statLabels.forEach((el, i) => {
    if (labels[i]) el.textContent = labels[i];
  });
}

// Update hero panel
function applyHeroPanel() {
  const bigPcts = document.querySelectorAll('.big-pct');
  const bigSubs = document.querySelectorAll('.big-pct-sub');
  if (bigPcts[0]) { bigPcts[0].textContent = D.ai_pct + '%'; bigSubs[0].textContent = D.total + '개 중 ' + D.ai_count + '개 AI 기반'; }
  if (bigPcts[1]) { bigPcts[1].textContent = D.agent_pct + '%'; bigSubs[1].textContent = '에이전트 기반 스타트업'; }

  // SR bars
  const srVals = document.querySelectorAll('.sr-val');
  const srBars = document.querySelectorAll('.sr-bar');
  const b2b = D.industries['B2B'];
  const hc = D.industries['Healthcare'];
  const edu = D.industries['Education'];
  if (srVals[0] && b2b) { srVals[0].textContent = b2b.ai_pct + '%'; srBars[0].style.width = b2b.ai_pct + '%'; }
  if (srVals[1] && hc)  { srVals[1].textContent = hc.ai_pct + '%';  srBars[1].style.width = hc.ai_pct + '%'; }
  if (srVals[2] && edu) { srVals[2].textContent = edu.ai_pct + '%'; srBars[2].style.width = edu.ai_pct + '%'; }
}

// Update numbers band
function applyNumbersBand() {
  const nbs = document.querySelectorAll('.nb-n');
  const nbls = document.querySelectorAll('.nb-l');
  const b2b = D.industries['B2B'];
  const vals = [
    { v: b2b ? b2b.ai_pct : 0, suf: '%', dec: 1, label: 'B2B 스타트업 AI 침투율' },
    { v: D.agent_count, suf: '개', dec: 0, label: 'AI 에이전트 스타트업' },
    { v: D.sub_industries['Supply Chain and Logistics'] ? parseFloat((D.sub_industries['Supply Chain and Logistics'].ai_pct/100 * 0.4 + D.sub_industries['Supply Chain and Logistics'].agent_pct/100 * 0.6).toFixed(2)) : 0.56, suf: '', dec: 2, label: 'Supply Chain 히트스코어' },
    { v: D.industries['Education'] ? D.industries['Education'].ai_pct : 91, suf: '%', dec: 1, label: 'Education AI 침투율' },
  ];
  nbs.forEach((el, i) => {
    if (vals[i]) {
      el.dataset.nbTarget = vals[i].v;
      el.dataset.nbSuf = vals[i].suf;
      el.dataset.nbDec = vals[i].dec;
    }
  });
  nbls.forEach((el, i) => {
    if (vals[i]) el.textContent = vals[i].label;
  });
}

// Update sector AI bars
function applySectorBars() {
  const hbarRows = document.querySelectorAll('.trend-card:first-child .hbar-row');
  const sectors = [
    ['Education', D.industries['Education']],
    ['Real Estate and Construction', D.industries['Real Estate and Construction']],
    ['Healthcare', D.industries['Healthcare']],
    ['B2B', D.industries['B2B']],
    ['Consumer', D.industries['Consumer']],
    ['Fintech', D.industries['Fintech']],
    ['Industrials', D.industries['Industrials']],
  ];
  hbarRows.forEach((row, i) => {
    if (!sectors[i]) return;
    const [name, ind] = sectors[i];
    if (!ind) return;
    const fill = row.querySelector('.hbar-fill');
    const val = row.querySelector('.hbar-val');
    const lbl = row.querySelector('.hbar-label');
    if (fill) fill.dataset.w = ind.ai_pct;
    if (val) val.textContent = ind.ai_pct + '%';
    if (lbl) lbl.textContent = name.replace(' and Construction','').replace('Real Estate','Real Estate');
  });
}

// Apply batch quarter chart data
function applyBatchChart() {
  const batches = ['Winter 2025', 'Spring 2025', 'Summer 2025', 'Fall 2025'];
  const ids = ['q1bar', 'q2bar', 'q3bar', 'q4bar'];
  ids.forEach((id, i) => {
    const el = document.getElementById(id);
    const b = D.batches[batches[i]];
    if (el && b) {
      el.style.height = '0';
      setTimeout(() => {
        el.style.transition = 'height 1s cubic-bezier(.16,1,.3,1)';
        el.style.height = (b.agent_pct / 25 * 100) + '%';
      }, 800);
      // Update label
      const parent = el.closest('[style*="flex-direction"]')?.parentElement;
      const numEl = parent?.querySelector('[style*="font-weight:700"]');
      if (numEl) numEl.textContent = b.agent_pct + '%';
    }
  });
}

// Update location bars
function applyLocationBars() {
  const geoRows = document.querySelectorAll('.geo-card:first-child .geo-row');
  const locs = [
    ['California', D.locations.California],
    ['New York', D.locations['New York']],
    ['United Kingdom', D.locations['United Kingdom']],
    ['Canada', D.locations.Canada],
    ['Remote/Unknown', D.locations['Remote/Unknown']],
  ];
  geoRows.forEach((row, i) => {
    if (!locs[i]) return;
    const fill = row.querySelector('.geo-fill');
    const val = row.querySelector('.geo-val');
    if (fill) fill.dataset.w = ((locs[i][1] / D.total) * 100).toFixed(1);
    if (val) val.textContent = locs[i][1] + '개';
  });
}

// Update archetypes
function applyArchetypes() {
  const archNums = document.querySelectorAll('.arch-n');
  const archFills = document.querySelectorAll('.arch-bar-fill');
  const archs = Object.entries(D.archetypes).sort((a,b) => b[1]-a[1]);
  const maxVal = archs[0]?.[1] || 1;
  archNums.forEach((el, i) => {
    if (archs[i]) el.textContent = archs[i][1];
  });
  archFills.forEach((el, i) => {
    if (archs[i]) el.dataset.w = ((archs[i][1] / maxVal) * 100).toFixed(0);
  });
}

// SEARCH / BROWSE COMPANIES
function buildCompanySearch() {
  const section = document.querySelector('#insights');
  if (!section) return;
  const wrap = document.createElement('div');
  wrap.className = 'wrap section-div';
  wrap.style.cssText = 'padding-bottom:0';
  wrap.id = 'companies';
  wrap.innerHTML = `
    <div class="section-label" style="display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:.59rem;font-weight:500;color:var(--chrome);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem"><span style="width:16px;height:.5px;background:var(--silver);display:block"></span>실시간 데이터</div>
    <h2 style="font-size:clamp(1.6rem,2.8vw,2.3rem);font-weight:800;letter-spacing:-.03em;color:var(--t1);line-height:1.1;margin-bottom:1.5rem">629개 스타트업<br>전체 검색</h2>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1.25rem">
      <div style="flex:1;min-width:220px;display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.7);border:.5px solid rgba(110,120,190,0.22);border-radius:40px;padding:10px 18px;backdrop-filter:blur(8px);box-shadow:0 2px 12px rgba(80,90,170,0.07)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--t3)" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input id="co-search" type="text" placeholder="스타트업 검색..." style="flex:1;border:none;outline:none;background:transparent;font-family:var(--font);font-size:.84rem;color:var(--t1)" />
      </div>
      <select id="co-batch" style="font-family:var(--font);font-size:.78rem;background:rgba(255,255,255,0.7);border:.5px solid rgba(110,120,190,0.22);border-radius:40px;padding:10px 18px;color:var(--t2);outline:none;cursor:pointer;backdrop-filter:blur(8px)">
        <option value="">전체 배치</option>
        ${['Winter 2025','Spring 2025','Summer 2025','Fall 2025'].map(b=>`<option>${b}</option>`).join('')}
      </select>
      <select id="co-industry" style="font-family:var(--font);font-size:.78rem;background:rgba(255,255,255,0.7);border:.5px solid rgba(110,120,190,0.22);border-radius:40px;padding:10px 18px;color:var(--t2);outline:none;cursor:pointer;backdrop-filter:blur(8px)">
        <option value="">전체 산업</option>
        ${[...new Set(D.companies.map(c=>c.industry).filter(Boolean))].map(i=>`<option>${i}</option>`).join('')}
      </select>
      <label style="display:flex;align-items:center;gap:7px;font-size:.78rem;color:var(--t2);cursor:pointer;background:rgba(255,255,255,0.7);border:.5px solid rgba(110,120,190,0.22);border-radius:40px;padding:10px 18px;backdrop-filter:blur(8px)">
        <input id="co-ai" type="checkbox" style="accent-color:var(--acc)"> AI만
      </label>
      <label style="display:flex;align-items:center;gap:7px;font-size:.78rem;color:var(--t2);cursor:pointer;background:rgba(255,255,255,0.7);border:.5px solid rgba(110,120,190,0.22);border-radius:40px;padding:10px 18px;backdrop-filter:blur(8px)">
        <input id="co-agent" type="checkbox" style="accent-color:var(--acc)"> 에이전트만
      </label>
    </div>
    <div id="co-count" style="font-family:var(--mono);font-size:.7rem;color:var(--t3);margin-bottom:.75rem">629개 표시 중</div>
    <div id="co-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;max-height:480px;overflow-y:auto;padding-right:4px"></div>
  `;
  section.parentNode.insertBefore(wrap, section);

  const grid = document.getElementById('co-grid');
  const countEl = document.getElementById('co-count');

  function renderCard(c) {
    const d = document.createElement('div');
    d.style.cssText = 'background:rgba(255,255,255,0.55);border:.5px solid rgba(255,255,255,0.85);border-radius:12px;padding:14px 16px;backdrop-filter:blur(12px);box-shadow:0 2px 12px rgba(80,90,170,0.07);transition:transform .2s;cursor:pointer';
    d.innerHTML = `
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px">
        <div style="font-size:.8rem;font-weight:700;color:var(--t1);letter-spacing:-.01em;line-height:1.2">${c.name}</div>
        <div style="display:flex;gap:4px;flex-shrink:0">
          ${c.is_agent ? '<span style="font-family:var(--mono);font-size:.52rem;font-weight:600;padding:2px 6px;border-radius:10px;background:rgba(72,82,176,0.08);color:var(--acc);border:.5px solid rgba(72,82,176,0.18)">Agent</span>' : ''}
          ${c.is_ai && !c.is_agent ? '<span style="font-family:var(--mono);font-size:.52rem;font-weight:600;padding:2px 6px;border-radius:10px;background:rgba(39,112,96,0.07);color:var(--grn);border:.5px solid rgba(39,112,96,0.18)">AI</span>' : ''}
        </div>
      </div>
      <div style="font-size:.7rem;color:var(--t3);line-height:1.55;margin-bottom:9px;font-weight:300">${c.desc.length>90 ? c.desc.slice(0,90)+'...' : c.desc}</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        ${c.batch ? `<span style="font-family:var(--mono);font-size:.55rem;padding:2px 7px;border-radius:8px;background:rgba(130,138,210,0.1);color:var(--chrome);border:.5px solid var(--bdr)">${c.batch}</span>` : ''}
        ${c.industry ? `<span style="font-family:var(--mono);font-size:.55rem;padding:2px 7px;border-radius:8px;background:rgba(130,138,210,0.08);color:var(--t3);border:.5px solid var(--bdr)">${c.industry}</span>` : ''}
      </div>
    `;
    d.addEventListener('mouseenter', () => d.style.transform = 'translateY(-2px)');
    d.addEventListener('mouseleave', () => d.style.transform = '');
    if (c.url && c.url !== 'nan') d.addEventListener('click', () => window.open(c.url, '_blank'));
    return d;
  }

  function filterAndRender() {
    const q = document.getElementById('co-search').value.toLowerCase();
    const batch = document.getElementById('co-batch').value;
    const ind = document.getElementById('co-industry').value;
    const aiOnly = document.getElementById('co-ai').checked;
    const agentOnly = document.getElementById('co-agent').checked;

    let filtered = D.companies.filter(c => {
      if (q && !c.name.toLowerCase().includes(q) && !c.desc.toLowerCase().includes(q)) return false;
      if (batch && c.batch !== batch) return false;
      if (ind && c.industry !== ind) return false;
      if (aiOnly && !c.is_ai) return false;
      if (agentOnly && !c.is_agent) return false;
      return true;
    });

    grid.innerHTML = '';
    countEl.textContent = filtered.length + '개 표시 중';
    filtered.slice(0, 120).forEach(c => grid.appendChild(renderCard(c)));
  }

  ['co-search','co-batch','co-industry','co-ai','co-agent'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', filterAndRender);
    if (el) el.addEventListener('change', filterAndRender);
  });

  filterAndRender();
}

// ── CSV DOWNLOAD ─────────────────────────────────────────────────────
function downloadCSV() {
  const headers = ['company_name','company_description','batch_name','industry','sub_industry','location','is_ai','is_agent','company_url'];
  const rows = D.companies.map(c => [
    c.name, c.desc, c.batch, c.industry, c.sub, c.location,
    c.is_ai ? 'true' : 'false',
    c.is_agent ? 'true' : 'false',
    c.url
  ].map(v => `"${String(v ?? '').replace(/"/g, '""')}"`).join(','));

  const csv = [headers.join(','), ...rows].join('\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'YC_2025_StartupSignal.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 3000);
}


// Number counter animation triggered by scroll (overrides the static values)
const counterObs = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    // hs-n counters
    entry.target.querySelectorAll('.hs-n[data-target]').forEach(el => {
      countUp(el, parseFloat(el.dataset.target), el.dataset.suffix || '', parseInt(el.dataset.dec || 0));
    });
    // nb-n counters
    entry.target.querySelectorAll('.nb-n[data-nb-target]').forEach(el => {
      const t = parseFloat(el.dataset.nbTarget);
      const suf = el.dataset.nbSuf || '';
      const dec = parseInt(el.dataset.nbDec || 0);
      let start = null;
      const step = ts => {
        if (!start) start = ts;
        const p = Math.min((ts - start) / 1400, 1);
        const ease = 1 - Math.pow(1 - p, 3);
        const val = (t * ease).toFixed(dec);
        el.innerHTML = val + '<span>' + suf + '</span>';
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    });
    counterObs.unobserve(entry.target);
  });
}, { threshold: 0.3 });

document.querySelectorAll('.hero-stats, .nb').forEach(el => counterObs.observe(el));
</script>

